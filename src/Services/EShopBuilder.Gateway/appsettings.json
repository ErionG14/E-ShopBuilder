{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/identity"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/catalog/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/catalog"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      },
      "store-route": {
        "ClusterId": "store-cluster",
        "Match": {
          "Path": "/api/store/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/store" },
          { "PathPrefix": "/api" }
        ]
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": {
          "Path": "/api/cart/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/cart" },
          { "PathPrefix": "/api" }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/order/{**remainder}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/order" },
          { "PathPrefix": "/api" }
        ]
      },
      "subscription-route": {
        "ClusterId": "subscription-cluster",
        "Match": {
          "Path": "/api/subscription/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**remainder}" }
        ]
      },
      "stripe-webhook-route": {
        "ClusterId": "subscription-cluster",
        "Match": {
          "Path": "/api/webhook"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5275"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5090"
          }
        }
      },
      "store-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5070"
          }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5102"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5050"
          }
        }
      },
      "subscription-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5285"
          }
        }
      }
    }
  }
}
